{
  "retriever": {
    "rrf": {
      "retrievers": [
        {
          "standard": {
            "query": {
              "multi_match": {
                "query": "{{query_text}}",
                "fields": ["title", "description"]
              }
            }
          }
        },
        {
          "knn": {
            "field": "embedding",
            "query_vector": "{{query_vector}}",
            "k": "{{k}}",
            "num_candidates": "{{num_candidates}}",
            "rescore_vector": {
              "oversample": "{{oversample}}"
            }
          }
        }
      ],
      "rank_window_size": "{{rank}}"
    }
  },
  "size": "{{size}}"
}
